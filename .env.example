# Flywheel OS — environment
# Copy to .env.local for local dev, or set in your Vercel project settings.

# Brevo (lead-capture provider). When BREVO_API_KEY is set, captured leads
# are synced to Brevo as contacts; when it's absent, capture safely falls
# back to console logging so preview deploys never break signups.
# Create a key at: Brevo → SMTP & API → API Keys.
BREVO_API_KEY=

# Optional: numeric id of the Brevo list new contacts are added to.
# Find it in Brevo → Contacts → Lists (the number in the list URL).
BREVO_LIST_ID=

# Nurture sending (Brevo transactional email/SMS). Required for the
# nurture engine to actually send emails; without a verified sender it
# falls back to console logging.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Game Integrity Journal
# Optional: alphanumeric sender id to enable transactional SMS steps.
BREVO_SMS_SENDER=

# Absolute site URL used to build offer CTA links inside nurture emails.
NEXT_PUBLIC_SITE_URL=https://gameintegrityjournal.com

# Optional: shared secret protecting the /api/nurture/tick cron endpoint.
# Set the same value in Vercel; the cron calls it as "Bearer <secret>".
CRON_SECRET=

